{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cockpit-dev/flutter_cockpit/docs/contracts/control-workflow.schema.json",
  "title": "Flutter Cockpit Control Workflow Script",
  "type": "object",
  "additionalProperties": true,
  "required": ["sessionId", "taskId", "platform"],
  "anyOf": [
    {
      "required": ["commands"]
    },
    {
      "required": ["steps"]
    }
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "default": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "recording": {
      "$ref": "#/$defs/recordingRequest"
    },
    "failFast": {
      "type": "boolean",
      "default": true
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflowStep"
      }
    }
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "flutterVersion": {
          "type": "string"
        },
        "dartVersion": {
          "type": "string"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": true,
      "required": ["commandId", "commandType"],
      "properties": {
        "commandId": {
          "type": "string",
          "minLength": 1
        },
        "commandType": {
          "$ref": "#/$defs/commandType"
        },
        "locator": {
          "$ref": "#/$defs/locator"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "capturePolicy": {
          "type": "string",
          "enum": [
            "none",
            "afterAction",
            "onFailure",
            "afterActionAndFailure"
          ],
          "default": "none"
        },
        "captureFailurePolicy": {
          "type": "string",
          "enum": ["failCommand", "degradeCommand"],
          "default": "failCommand"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "snapshotOptions": {
          "$ref": "#/$defs/snapshotOptions"
        },
        "screenshotRequest": {
          "$ref": "#/$defs/screenshotRequest"
        }
      }
    },
    "commandType": {
      "type": "string",
      "enum": [
        "tap",
        "enterText",
        "focusTextInput",
        "setTextEditingValue",
        "sendTextInputAction",
        "sendKeyEvent",
        "sendKeyDownEvent",
        "sendKeyUpEvent",
        "longPress",
        "doubleTap",
        "drag",
        "fling",
        "swipe",
        "pinchZoom",
        "rotate",
        "panZoom",
        "multiTouch",
        "scrollUntilVisible",
        "clearNetworkActivity",
        "waitForNetworkIdle",
        "waitForUiIdle",
        "back",
        "showOnScreen",
        "increase",
        "decrease",
        "dismiss",
        "dismissKeyboard",
        "waitFor",
        "assertVisible",
        "assertText",
        "captureScreenshot",
        "collectSnapshot"
      ]
    },
    "locator": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cockpitId": {
          "type": "string",
          "minLength": 1
        },
        "semanticId": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "tooltip": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string",
          "minLength": 1
        },
        "registrationId": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "ancestor": {
          "$ref": "#/$defs/locator"
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/locator"
          },
          "default": []
        }
      },
      "not": {
        "anyOf": [
          {
            "required": ["kind"]
          },
          {
            "required": ["value"]
          }
        ]
      }
    },
    "snapshotOptions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["live", "baseline", "investigate", "forensic"],
          "default": "live"
        },
        "maxTargets": {
          "type": "integer",
          "minimum": 0,
          "default": 25
        },
        "maxAncestorsPerTarget": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxPropertiesPerTarget": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "includeStyleDetails": {
          "type": "boolean",
          "default": false
        },
        "includeDiagnosticProperties": {
          "type": "boolean",
          "default": false
        },
        "emitArtifactWhenLarge": {
          "type": "boolean",
          "default": false
        },
        "includeRebuildActivity": {
          "type": "boolean",
          "default": false
        },
        "maxRebuildEntries": {
          "type": "integer",
          "minimum": 0,
          "default": 8
        },
        "includeNetworkActivity": {
          "type": "boolean",
          "default": false
        },
        "maxNetworkEntries": {
          "type": "integer",
          "minimum": 0,
          "default": 8
        },
        "networkQuery": {
          "$ref": "#/$defs/networkQuery"
        },
        "includeRuntimeActivity": {
          "type": "boolean",
          "default": false
        },
        "maxRuntimeEntries": {
          "type": "integer",
          "minimum": 0,
          "default": 8
        },
        "runtimeQuery": {
          "$ref": "#/$defs/runtimeQuery"
        },
        "includeAccessibilitySummary": {
          "type": "boolean",
          "default": false
        },
        "maxAccessibilityEntries": {
          "type": "integer",
          "minimum": 0,
          "default": 8
        }
      }
    },
    "networkQuery": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "uriContains": {
          "type": "string",
          "minLength": 1
        },
        "onlyFailures": {
          "type": "boolean",
          "default": false
        },
        "statusCodeAtLeast": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        }
      }
    },
    "runtimeQuery": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "onlyErrors": {
          "type": "boolean",
          "default": false
        },
        "messageContains": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "screenshotRequest": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reason", "name"],
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "baseline",
            "before_action",
            "after_action",
            "assertion_failure",
            "acceptance"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "includeSnapshot": {
          "type": "boolean",
          "default": false
        },
        "attachToStep": {
          "type": "boolean",
          "default": false
        },
        "snapshotOptions": {
          "$ref": "#/$defs/snapshotOptions"
        }
      }
    },
    "workflowStep": {
      "oneOf": [
        {
          "$ref": "#/$defs/commandStep"
        },
        {
          "$ref": "#/$defs/startRecordingStep"
        },
        {
          "$ref": "#/$defs/stopRecordingStep"
        },
        {
          "$ref": "#/$defs/ifStep"
        },
        {
          "$ref": "#/$defs/loopStep"
        },
        {
          "$ref": "#/$defs/retryStep"
        }
      ]
    },
    "recordingRequest": {
      "type": "object",
      "additionalProperties": true,
      "required": ["purpose", "name"],
      "properties": {
        "purpose": {
          "type": "string",
          "enum": ["acceptance", "repro", "diagnostic", "debug", "investigation"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["auto", "cheap", "native", "full"],
          "default": "auto"
        },
        "layer": {
          "type": "string",
          "enum": ["flutter", "app-window", "host-screen", "system"]
        },
        "allowFallback": {
          "type": "boolean"
        },
        "attachToStep": {
          "type": "boolean",
          "default": false
        },
        "tailStabilizationMs": {
          "type": "integer",
          "minimum": 0,
          "default": 1400
        }
      }
    },
    "stepBase": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stepType"],
      "properties": {
        "stepId": {
          "type": "string",
          "minLength": 1
        },
        "stepType": {
          "type": "string"
        }
      }
    },
    "commandStep": {
      "allOf": [
        {
          "$ref": "#/$defs/stepBase"
        },
        {
          "type": "object",
          "required": ["command"],
          "properties": {
            "stepType": {
              "const": "command"
            },
            "command": {
              "$ref": "#/$defs/command"
            }
          }
        }
      ]
    },
    "startRecordingStep": {
      "allOf": [
        {
          "$ref": "#/$defs/stepBase"
        },
        {
          "type": "object",
          "required": ["recording"],
          "properties": {
            "stepType": {
              "const": "startRecording"
            },
            "recording": {
              "$ref": "#/$defs/recordingRequest"
            }
          }
        }
      ]
    },
    "stopRecordingStep": {
      "allOf": [
        {
          "$ref": "#/$defs/stepBase"
        },
        {
          "type": "object",
          "properties": {
            "stepType": {
              "const": "stopRecording"
            },
            "settleMs": {
              "type": "integer",
              "minimum": 0,
              "default": 1400
            }
          }
        }
      ]
    },
    "ifStep": {
      "allOf": [
        {
          "$ref": "#/$defs/stepBase"
        },
        {
          "type": "object",
          "required": ["condition"],
          "properties": {
            "stepType": {
              "const": "if"
            },
            "condition": {
              "$ref": "#/$defs/command"
            },
            "thenSteps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/workflowStep"
              },
              "default": []
            },
            "elseSteps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/workflowStep"
              },
              "default": []
            }
          }
        }
      ]
    },
    "loopStep": {
      "allOf": [
        {
          "$ref": "#/$defs/stepBase"
        },
        {
          "type": "object",
          "required": ["condition", "maxIterations", "steps"],
          "properties": {
            "stepType": {
              "const": "loop"
            },
            "condition": {
              "$ref": "#/$defs/command"
            },
            "maxIterations": {
              "type": "integer",
              "minimum": 1
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/workflowStep"
              }
            }
          }
        }
      ]
    },
    "retryStep": {
      "allOf": [
        {
          "$ref": "#/$defs/stepBase"
        },
        {
          "type": "object",
          "required": ["step"],
          "properties": {
            "stepType": {
              "const": "retry"
            },
            "maxAttempts": {
              "type": "integer",
              "minimum": 1,
              "default": 3
            },
            "delayMs": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "step": {
              "$ref": "#/$defs/commandStep"
            }
          }
        }
      ]
    }
  }
}
